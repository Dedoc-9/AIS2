# AIS² Git Attributes Configuration

# Auto detect text files and normalize line endings to LF
* text=auto

# Python files
*.py text eol=lf
*.pyx text eol=lf
*.pyi text eol=lf
*.pyc text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows batch files
*.cmd text eol=crlf
*.bat text eol=crlf

# JSON and YAML
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Markdown
*.md text eol=lf

# TOML and INI
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Text files
*.txt text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.otf binary
*.db binary

# Documentation
LICENSE text eol=lf
README.md text eol=lf
CONTRIBUTING.md text eol=lf
CHANGELOG.md text eol=lf
